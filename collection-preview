<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Beard Butter Collection — Live Preview | Maxout Brands × Maestro's Classic</title>
<meta name="description" content="Walkthrough preview of the new Beard Butter collection page for Maestro's Classic. Built by Maxout Brands.">

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..900;1,9..144,300..900&family=Inter+Tight:wght@300..800&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">

<style>
  :root {
    --bg: #1a1a1a;
    --bg-2: #141414;
    --surface: #2e2e2e;
    --surface-2: #262626;
    --surface-3: #363636;
    --primary: #733486;
    --primary-glow: rgba(115, 52, 134, 0.35);
    --secondary: #6bacc8;
    --accent: #6490c3;
    --text: #eaeaea;
    --text-dim: #9a9a9a;
    --text-low: #6a6a6a;
    --border: #333333;
    --border-light: #2a2a2a;
    --browser-chrome: #242424;
    --browser-chrome-2: #2c2c2c;
    --browser-url: #171717;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }

  body {
    font-family: 'Inter Tight', system-ui, sans-serif;
    background: var(--bg);
    color: var(--text);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
    overflow-x: hidden;
  }

  body::before {
    content: '';
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 1;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='2' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.5'/%3E%3C/svg%3E");
    opacity: 0.025;
    mix-blend-mode: overlay;
  }

  ::selection { background: var(--primary); color: #fff; }

  .mono {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  /* ============ TOP BAR ============ */
  .topbar {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(20, 20, 20, 0.82);
    backdrop-filter: blur(20px) saturate(140%);
    -webkit-backdrop-filter: blur(20px) saturate(140%);
    border-bottom: 1px solid var(--border-light);
  }
  .topbar-inner {
    max-width: 1600px;
    margin: 0 auto;
    padding: 1rem 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
    letter-spacing: 0.04em;
    color: var(--text);
  }
  .brand-dot {
    width: 8px; height: 8px;
    background: var(--primary);
    border-radius: 50%;
    box-shadow: 0 0 12px var(--primary-glow);
  }
  .brand strong { font-weight: 600; }
  .brand .sep { color: var(--text-low); }
  .back-link {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-dim);
    text-decoration: none;
    transition: color 0.2s;
  }
  .back-link:hover { color: var(--text); }

  /* ============ HERO ============ */
  .hero {
    position: relative;
    max-width: 1600px;
    margin: 0 auto;
    padding: 6rem 2rem 3rem;
    z-index: 2;
  }
  .hero-kicker {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.4rem 0.85rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 999px;
    margin-bottom: 2rem;
  }
  .hero-kicker::before {
    content: '';
    width: 6px; height: 6px;
    background: var(--secondary);
    border-radius: 50%;
    box-shadow: 0 0 10px var(--secondary);
  }
  .hero-title {
    font-family: 'Fraunces', serif;
    font-weight: 300;
    font-size: clamp(2.6rem, 6.5vw, 5.5rem);
    line-height: 0.98;
    letter-spacing: -0.03em;
    margin-bottom: 1.75rem;
    max-width: 1200px;
    font-variation-settings: 'opsz' 144;
  }
  .hero-title em {
    font-style: italic;
    font-weight: 300;
    color: var(--secondary);
  }
  .hero-title strong { font-weight: 600; }
  .hero-sub {
    font-size: clamp(1rem, 1.3vw, 1.15rem);
    color: var(--text-dim);
    max-width: 720px;
    line-height: 1.65;
  }

  /* ============ WALKTHROUGH LAYOUT ============ */
  .walkthrough {
    max-width: 1600px;
    margin: 0 auto;
    padding: 2rem 2rem 6rem;
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 3rem;
    position: relative;
    z-index: 2;
  }
  @media (max-width: 1000px) {
    .walkthrough { grid-template-columns: 1fr; gap: 1.5rem; }
  }

  .section-nav {
    position: sticky;
    top: 100px;
    align-self: start;
    height: fit-content;
  }
  .section-nav .mono {
    color: var(--text-low);
    margin-bottom: 1.5rem;
    display: block;
    padding-left: 0.25rem;
  }
  .nav-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    border-left: 1px solid var(--border);
    padding-left: 0;
  }
  .nav-item { margin-left: -1px; }
  .nav-item a {
    display: flex;
    align-items: flex-start;
    gap: 0.85rem;
    padding: 0.85rem 1rem 0.85rem 1.15rem;
    color: var(--text-low);
    text-decoration: none;
    border-left: 2px solid transparent;
    transition: all 0.3s cubic-bezier(.2,.8,.2,1);
    font-family: 'Inter Tight', sans-serif;
  }
  .nav-item a:hover {
    color: var(--text-dim);
    border-left-color: var(--border);
  }
  .nav-num {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    padding-top: 0.2rem;
    flex-shrink: 0;
    color: var(--text-low);
    transition: color 0.3s;
  }
  .nav-label {
    font-size: 0.88rem;
    font-weight: 500;
    line-height: 1.35;
    letter-spacing: -0.005em;
  }
  .nav-desc {
    display: block;
    font-size: 0.75rem;
    color: var(--text-low);
    margin-top: 0.35rem;
    line-height: 1.5;
    font-weight: 400;
    max-height: 0;
    opacity: 0;
    overflow: hidden;
    transition: max-height 0.4s cubic-bezier(.2,.8,.2,1), opacity 0.3s, margin-top 0.3s;
  }
  .nav-item.active a {
    color: var(--text);
    border-left-color: var(--primary);
    background: linear-gradient(90deg, rgba(115, 52, 134, 0.08) 0%, transparent 80%);
  }
  .nav-item.active .nav-num { color: var(--primary); }
  .nav-item.active .nav-desc {
    max-height: 100px;
    opacity: 1;
  }
  @media (max-width: 1000px) {
    .section-nav {
      position: sticky;
      top: 64px;
      background: rgba(20, 20, 20, 0.9);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      padding: 0.75rem 1rem;
      margin: 0 -2rem;
      border-bottom: 1px solid var(--border-light);
      z-index: 50;
    }
    .section-nav > .mono { display: none; }
    .nav-list {
      flex-direction: row;
      border-left: none;
      overflow-x: auto;
      padding: 0;
      gap: 0;
      scrollbar-width: none;
    }
    .nav-list::-webkit-scrollbar { display: none; }
    .nav-item a {
      border-left: none;
      border-bottom: 2px solid transparent;
      padding: 0.5rem 0.9rem;
      white-space: nowrap;
    }
    .nav-item.active a {
      border-left: none;
      border-bottom-color: var(--primary);
      background: none;
    }
    .nav-desc { display: none !important; }
  }

  /* ============ BROWSER WINDOW ============ */
  .browser-window {
    background: #fff;
    border-radius: 14px;
    overflow: hidden;
    box-shadow:
      0 50px 100px -30px rgba(0, 0, 0, 0.65),
      0 20px 40px -20px rgba(0, 0, 0, 0.5),
      0 0 0 1px var(--border-light);
    position: relative;
  }

  .browser-chrome {
    background: linear-gradient(180deg, var(--browser-chrome-2) 0%, var(--browser-chrome) 100%);
    padding: 0.75rem 1rem;
    display: flex;
    align-items: center;
    gap: 1rem;
    border-bottom: 1px solid rgba(0, 0, 0, 0.4);
    position: sticky;
    top: 72px;
    z-index: 20;
  }
  @media (max-width: 1000px) {
    .browser-chrome { top: 124px; }
  }

  .traffic-lights {
    display: flex;
    gap: 0.45rem;
    flex-shrink: 0;
  }
  .tl {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    border: 0.5px solid rgba(0, 0, 0, 0.2);
  }
  .tl-r { background: #ff5f57; }
  .tl-y { background: #febc2e; }
  .tl-g { background: #28c840; }

  .browser-url {
    flex: 1;
    background: var(--browser-url);
    border-radius: 7px;
    padding: 0.45rem 0.85rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.78rem;
    color: var(--text-dim);
    display: flex;
    align-items: center;
    gap: 0.6rem;
    border: 1px solid rgba(255, 255, 255, 0.04);
    max-width: 640px;
    margin: 0 auto;
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
  }
  .lock-icon {
    width: 11px;
    height: 11px;
    flex-shrink: 0;
    fill: var(--text-low);
  }
  .url-secure { color: var(--text-low); }
  .url-path { color: var(--text); }

  .browser-actions {
    display: flex;
    gap: 0.5rem;
    flex-shrink: 0;
    opacity: 0.4;
  }
  .browser-action {
    width: 22px;
    height: 22px;
    border-radius: 4px;
    background: rgba(255,255,255,0.05);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .browser-action svg { width: 12px; height: 12px; fill: var(--text-dim); }
  @media (max-width: 700px) {
    .browser-actions { display: none; }
    .browser-url { font-size: 0.7rem; }
  }

  .browser-content {
    background: #fff;
    position: relative;
  }
  .page-section {
    display: block;
    position: relative;
    scroll-margin-top: 130px;
  }
  .page-section img {
    display: block;
    width: 100%;
    height: auto;
    background: #fff;
  }

  /* active section indicator */
  .page-section::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 3px;
    height: 100%;
    background: var(--primary);
    opacity: 0;
    transition: opacity 0.4s ease;
    z-index: 5;
  }
  .page-section.active::before { opacity: 0.7; }

  /* floating section badge */
  .section-badge {
    position: absolute;
    top: 24px;
    left: 24px;
    z-index: 10;
    background: rgba(20, 20, 20, 0.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    color: #fff;
    padding: 0.55rem 0.85rem;
    border-radius: 8px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border: 1px solid rgba(255,255,255,0.08);
    opacity: 0;
    transform: translateY(-8px);
    transition: opacity 0.4s, transform 0.4s;
    display: flex;
    align-items: center;
    gap: 0.6rem;
    pointer-events: none;
    box-shadow: 0 10px 30px rgba(0,0,0,0.4);
  }
  .section-badge .badge-num { color: var(--secondary); font-weight: 600; }
  .section-badge .badge-sep { color: var(--text-low); }
  .page-section.active .section-badge {
    opacity: 1;
    transform: translateY(0);
  }
  @media (max-width: 700px) {
    .section-badge { top: 12px; left: 12px; font-size: 0.62rem; padding: 0.4rem 0.65rem; }
  }

  /* floating scroll indicator */
  .scroll-indicator {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    z-index: 50;
    background: rgba(20, 20, 20, 0.9);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    padding: 0.75rem 1rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    color: var(--text-dim);
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.3s, transform 0.3s;
    box-shadow: 0 10px 40px rgba(0,0,0,0.4);
    pointer-events: none;
  }
  .scroll-indicator.visible {
    opacity: 1;
    transform: translateY(0);
  }
  .scroll-dots { display: flex; gap: 4px; }
  .scroll-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--text-low);
    transition: background 0.3s, transform 0.3s;
  }
  .scroll-dot.active {
    background: var(--primary);
    transform: scale(1.4);
  }
  @media (max-width: 700px) { .scroll-indicator { display: none; } }

  /* ============ IMPACT ============ */
  .impact {
    max-width: 1600px;
    margin: 0 auto;
    padding: 6rem 2rem;
    border-top: 1px solid var(--border);
    position: relative;
    z-index: 2;
  }
  .impact-head { margin-bottom: 3.5rem; max-width: 900px; }
  .impact-kicker {
    display: inline-block;
    margin-bottom: 1.5rem;
    color: var(--primary);
  }
  .impact-title {
    font-family: 'Fraunces', serif;
    font-weight: 300;
    font-size: clamp(2rem, 4.5vw, 3.75rem);
    line-height: 1.02;
    letter-spacing: -0.02em;
    font-variation-settings: 'opsz' 144;
  }
  .impact-title em { font-style: italic; color: var(--secondary); }
  .impact-title strong { font-weight: 600; }
  .impact-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  @media (max-width: 900px) { .impact-grid { grid-template-columns: 1fr; } }
  .impact-card {
    background: linear-gradient(160deg, var(--surface) 0%, var(--surface-2) 100%);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 2rem;
    position: relative;
    overflow: hidden;
  }
  .impact-card::before {
    content: '';
    position: absolute;
    top: -40%;
    right: -20%;
    width: 280px;
    height: 280px;
    background: radial-gradient(circle, var(--primary-glow) 0%, transparent 70%);
    opacity: 0.4;
    pointer-events: none;
  }
  .impact-card .mono {
    color: var(--primary);
    display: block;
    margin-bottom: 1rem;
  }
  .impact-card h3 {
    font-family: 'Fraunces', serif;
    font-weight: 500;
    font-size: 1.5rem;
    line-height: 1.2;
    letter-spacing: -0.01em;
    margin-bottom: 1rem;
    position: relative;
    z-index: 1;
    font-variation-settings: 'opsz' 144;
  }
  .impact-card p {
    color: var(--text-dim);
    font-size: 0.95rem;
    line-height: 1.65;
    position: relative;
    z-index: 1;
  }
  .impact-card p strong { color: var(--text); font-weight: 600; }

  /* ============ FOOTER ============ */
  .footer {
    max-width: 1600px;
    margin: 0 auto;
    padding: 3rem 2rem;
    border-top: 1px solid var(--border);
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
    position: relative;
    z-index: 2;
  }
  .footer-left {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
    color: var(--text-low);
    letter-spacing: 0.04em;
  }
  .footer-right { display: flex; gap: 1.5rem; }
  .footer-right a {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-dim);
    text-decoration: none;
    transition: color 0.2s;
  }
  .footer-right a:hover { color: var(--text); }

  .fade-in {
    opacity: 0;
    transform: translateY(18px);
    animation: fadeUp 0.9s cubic-bezier(.2,.8,.2,1) forwards;
  }
  .fade-in.delay-1 { animation-delay: 0.1s; }
  .fade-in.delay-2 { animation-delay: 0.2s; }
  .fade-in.delay-3 { animation-delay: 0.35s; }
  @keyframes fadeUp { to { opacity: 1; transform: translateY(0); } }
</style>
</head>
<body>

<header class="topbar">
  <div class="topbar-inner">
    <div class="brand">
      <span class="brand-dot"></span>
      <strong>Maxout Brands</strong>
      <span class="sep">×</span>
      <span>Maestro's Classic</span>
    </div>
    <a class="back-link" href="https://maxout-brian.github.io/maestros-classic/">← Portal</a>
  </div>
</header>

<section class="hero">
  <div class="hero-kicker fade-in">
    <span class="mono">Live Page Preview · Beard Butter Collection</span>
  </div>
  <h1 class="hero-title fade-in delay-1">
    What the new <em>Beard Butter</em><br>
    collection page will <strong>look like</strong>.
  </h1>
  <p class="hero-sub fade-in delay-2">
    Scroll through all six sections as they'll appear on maestrosclassic.com.
    The nav on the left tracks where you are — click a section to jump to it.
  </p>
</section>

<main class="walkthrough">

  <aside class="section-nav fade-in delay-3" aria-label="Section navigation">
    <span class="mono">Sections</span>
    <ul class="nav-list">
      <li class="nav-item" data-target="s1">
        <a href="#s1">
          <span class="nav-num">01</span>
          <span>
            <span class="nav-label">Hero &amp; product grid</span>
            <span class="nav-desc">Keyword-optimized H1, trust bar, and a scent-differentiated product grid.</span>
          </span>
        </a>
      </li>
      <li class="nav-item" data-target="s2">
        <a href="#s2">
          <span class="nav-num">02</span>
          <span>
            <span class="nav-label">Reviews &amp; how-to</span>
            <span class="nav-desc">2,253-review aggregate, verified carousel, and a 3-step usage guide.</span>
          </span>
        </a>
      </li>
      <li class="nav-item" data-target="s3">
        <a href="#s3">
          <span class="nav-num">03</span>
          <span>
            <span class="nav-label">Compare tabs</span>
            <span class="nav-desc">Side-by-side comparisons against Oil, Wash, and Recovery.</span>
          </span>
        </a>
      </li>
      <li class="nav-item" data-target="s4">
        <a href="#s4">
          <span class="nav-num">04</span>
          <span>
            <span class="nav-label">Journal cluster</span>
            <span class="nav-desc">Featured blog articles that wire into the broader topical cluster.</span>
          </span>
        </a>
      </li>
      <li class="nav-item" data-target="s5">
        <a href="#s5">
          <span class="nav-num">05</span>
          <span>
            <span class="nav-label">Maestro's Pledge</span>
            <span class="nav-desc">Six trust pillars placed at the decision moment.</span>
          </span>
        </a>
      </li>
      <li class="nav-item" data-target="s6">
        <a href="#s6">
          <span class="nav-num">06</span>
          <span>
            <span class="nav-label">Copy &amp; FAQ</span>
            <span class="nav-desc">400+ words of keyword-rich copy and 12 FAQ pairs for schema.</span>
          </span>
        </a>
      </li>
    </ul>
  </aside>

  <article class="browser-window fade-in delay-3">
    <div class="browser-chrome">
      <div class="traffic-lights">
        <span class="tl tl-r"></span>
        <span class="tl tl-y"></span>
        <span class="tl tl-g"></span>
      </div>
      <div class="browser-url">
        <svg class="lock-icon" viewBox="0 0 24 24"><path d="M12 1a5 5 0 0 1 5 5v3h1a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V11a2 2 0 0 1 2-2h1V6a5 5 0 0 1 5-5zm0 2a3 3 0 0 0-3 3v3h6V6a3 3 0 0 0-3-3z"/></svg>
        <span class="url-secure">https://</span><span class="url-path">maestrosclassic.com/collections/beard-butter</span>
      </div>
      <div class="browser-actions">
        <span class="browser-action"><svg viewBox="0 0 24 24"><path d="M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2zm0 18a8 8 0 1 1 8-8 8 8 0 0 1-8 8z"/></svg></span>
        <span class="browser-action"><svg viewBox="0 0 24 24"><path d="M4 6h16v2H4zm0 5h16v2H4zm0 5h16v2H4z"/></svg></span>
      </div>
    </div>

    <div class="browser-content">
      <section class="page-section" id="s1">
        <span class="section-badge"><span class="badge-num">01</span><span class="badge-sep">·</span><span>Hero &amp; product grid</span></span>
        <img src="images/01-hero-trust-products.png" alt="Beard Butter Collection hero, trust bar, and product grid" loading="eager">
      </section>
